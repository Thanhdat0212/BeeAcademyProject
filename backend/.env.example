# ============================================================================
# Bee Academy Backend - Environment Variables Template
# ----------------------------------------------------------------------------
# Copy file này thành .env (cùng thư mục backend/) và điền giá trị thật.
# KHÔNG commit .env vào git.
# Cách lấy các giá trị Supabase:
#   1. Vào https://supabase.com/dashboard/project/haksqgakssvmlbxtqxir
#   2. Project Settings → API
#      - SUPABASE_URL          = "Project URL"
#      - SUPABASE_ANON_KEY     = "anon public" key
#      - SUPABASE_SERVICE_ROLE_KEY = "service_role secret" key (BÍ MẬT)
#      - SUPABASE_JWT_SECRET   = "JWT Secret" (BÍ MẬT) - dùng verify token
#   3. Project Settings → Database → Connection string → URI
#      - SUPABASE_DB_PASSWORD  = mật khẩu Postgres
# ============================================================================

# --- Supabase API ---
SUPABASE_URL=https://haksqgakssvmlbxtqxir.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Supabase Postgres (JDBC) ---
SUPABASE_DB_HOST=db.haksqgakssvmlbxtqxir.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# --- Mail (Gmail SMTP) ---
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Application ---
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
