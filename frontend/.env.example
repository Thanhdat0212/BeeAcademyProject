# =============================================================================
# Bee Academy Frontend - Environment Variables Template
# -----------------------------------------------------------------------------
# Copy file này thành .env.local (cùng thư mục frontend/) để Vite load.
# Vite CHỈ expose biến có prefix VITE_* ra client - không nhét secret.
# =============================================================================

# Base URL của backend Spring Boot. Đổi khi deploy lên production.
VITE_API_BASE_URL=http://localhost:8080

# Supabase project URL (public - an toàn để expose ra frontend)
VITE_SUPABASE_URL=https://haksqgakssvmlbxtqxir.supabase.co

# ---------- AI Studio legacy (không dùng trong runtime hiện tại) ----------
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
