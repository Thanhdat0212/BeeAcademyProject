  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[Hook] Chuẩn bị chạy lệnh Bash...\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "copy \"%CLAUDE_TOOL_INPUT_FILE%\" \"%CLAUDE_TOOL_INPUT_FILE%.bak\" 2>$null; exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[Hook] File đã được chỉnh sửa.\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[Hook] File mới đã được tạo.\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"%CLAUDE_TOOL_OUTPUT_FILE%\" 2>$null; exit 0"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[Hook] Thông báo từ Claude: $CLAUDE_NOTIFICATION\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[Hook] Claude đã dừng phiên làm việc.\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[Hook] Subagent đã hoàn thành.\""
          }
        ]
      }
    ]
  }
